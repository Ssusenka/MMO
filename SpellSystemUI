-- 5. FUNKCE PRO TOOLTIP (Musí být nad makeDraggable, aby ji viděl)
local function updateTooltip(name, description)
	if name and description then
		tooltipTitle.Text = name
		tooltipDesc.Text = description
		tooltip.Visible = true
		local mouseLoc = UIS:GetMouseLocation()
		tooltip.Position = UDim2.new(0, mouseLoc.X + 15, 0, mouseLoc.Y - 35)
	else
		tooltip.Visible = false
	end
end

-- Sledování pohybu myši pro tooltip
UIS.InputChanged:Connect(function(input)
	if tooltip.Visible and input.UserInputType == Enum.UserInputType.MouseMovement then
		local mouseLoc = UIS:GetMouseLocation()
		tooltip.Position = UDim2.new(0, mouseLoc.X + 15, 0, mouseLoc.Y - 35)
	end
end)

-- 5. POMOCNÁ FUNKCE PRO POHYB
local Controls = nil
local function getControls()
	if not Controls then
		pcall(function()
			local pScripts = player:WaitForChild("PlayerScripts", 2)
			if pScripts then
				local pModule = pScripts:WaitForChild("PlayerModule", 2)
				if pModule then
					Controls = require(pModule):GetControls()
				end
			end
		end)
	end
	return Controls
end
