local dragScreen = Instance.new("ScreenGui", pGui); dragScreen.Name = "DragGhostGui"; dragScreen.DisplayOrder = 100; dragScreen.IgnoreGuiInset = true
local ghostIcon = Instance.new("TextLabel", dragScreen)
ghostIcon.Size = UDim2.new(0, 75, 0, 75); ghostIcon.BackgroundColor3 = COLORS.Highlight; ghostIcon.BackgroundTransparency = 0.2; ghostIcon.TextColor3 = COLORS.Text; ghostIcon.Font = Enum.Font.GothamBold; ghostIcon.TextSize = 12; ghostIcon.TextWrapped = true; ghostIcon.Visible = false; createCorner(ghostIcon, 6); applyStroke(ghostIcon)
ghostIcon.AnchorPoint = Vector2.new(0.5, 0.5)

local draggingItem = nil; local dragType = nil

local function makeDraggable(parent, name, type)
	local btn = Instance.new("TextButton", parent)
	-- ... tvoje nastavení btn (barvy, text atd.) ...
	btn.Text = name

	-- EVENTY PRO TOOLTIP
	btn.MouseEnter:Connect(function()
		local curClass = selectedClassObj.Value
		if curClass == "" then curClass = "Magic" end

		local data = classData[curClass].Spells[name] or classData[curClass].Passives[name]
		if data then
			updateTooltip(name, data.Description)
		end
	end)

	btn.MouseLeave:Connect(function()
		updateTooltip(nil)
	end)

	-- DRAG EVENT
	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingItem = name; dragType = type
			ghostIcon.Text = name; ghostIcon.Visible = true
			updateTooltip(nil) -- Schováme tooltip při přetahování
			local mouseLoc = UIS:GetMouseLocation()
			ghostIcon.Position = UDim2.new(0, mouseLoc.X, 0, mouseLoc.Y)
		end
	end)
end

UIS.InputChanged:Connect(function(input)
	if draggingItem and input.UserInputType == Enum.UserInputType.MouseMovement then
		local mouseLoc = UIS:GetMouseLocation()
		ghostIcon.Position = UDim2.new(0, mouseLoc.X, 0, mouseLoc.Y)
	end
end)

UIS.InputEnded:Connect(function(input)
	if draggingItem and input.UserInputType == Enum.UserInputType.MouseButton1 then
		ghostIcon.Visible = false
		local dropPos = input.Position
		local guisAtPos = pGui:GetGuiObjectsAtPosition(dropPos.X, dropPos.Y)

		for _, gui in ipairs(guisAtPos) do
			if dragType == "Spell" and gui.Name:match("^HotbarSlot(%d+)$") then
				local index = tonumber(gui.Name:match("^HotbarSlot(%d+)$"))
				remote:FireServer("EquipSpell", {index = index, name = draggingItem, class = selectedClassObj.Value})
				break
			elseif dragType == "Passive" and gui.Name:match("^EqPassSlot(%d+)$") then
				local index = tonumber(gui.Name:match("^EqPassSlot(%d+)$"))
				remote:FireServer("EquipPassive", {index = index, name = draggingItem, class = selectedClassObj.Value})
				break
			end
		end
		draggingItem = nil; dragType = nil
	end
end)

local function refreshMenu()
	-- 1. Vyčištění starých ikon
	for _, v in pairs(pClasses:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
	for _, v in pairs(gridSpells:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
	for _, v in pairs(gridPassives:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end

	-- 2. Vykreslení tlačítek tříd
	for _, cName in pairs(CLASSES) do
		local btn = Instance.new("TextButton", pClasses)
		btn.Size = UDim2.new(0.85, 0, 0, 60)
		btn.BackgroundColor3 = COLORS.SlotBg
		btn.BackgroundTransparency = COLORS.PanelTrans
		createCorner(btn, 6)
		applyStroke(btn)

		btn.Text = string.upper(cName)
		btn.TextColor3 = COLORS.Text
		btn.Font = Enum.Font.GothamBlack
		btn.TextSize = 18

		if selectedClassObj.Value == cName then 
			btn.BackgroundColor3 = COLORS.Highlight
			btn.BackgroundTransparency = 0.5
		end
		btn.MouseButton1Click:Connect(function() remote:FireServer("SelectClass", cName) end)
	end

	-- 3. BEZPEČNÉ NAČTENÍ DAT (Tady byla ta chyba)
	local curClass = selectedClassObj.Value

	-- Pokud hráč ještě nemá zvolenou classu, zkusíme vzít první dostupnou nebo skončíme
	if curClass == "" or curClass == nil then 
		curClass = "Magic" -- Nastavíme Magic jako základní zobrazení
	end

	local dataForClass = classData[curClass]

	-- Kontrola, jestli data pro tuhle classu vůbec existují v tabulce classData
	if dataForClass then
		-- Načtení Spellů
		if dataForClass.Spells then
			for sName, sData in pairs(dataForClass.Spells) do
				makeDraggable(gridSpells, sName, "Spell")
			end
		end
		-- Načtení Passivek
		if dataForClass.Passives then
			for pName, pData in pairs(dataForClass.Passives) do
				makeDraggable(gridPassives, pName, "Passive")
			end
		end
	else
		warn("Varování: Pro třídu '" .. tostring(curClass) .. "' nebyla nalezena žádná data v ModuleScriptech!")
	end
end

