UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end

	if input.KeyCode == Enum.KeyCode.K then
		-- HLÍDAČ: Zeptáme se, jestli není otevřené P menu. Pokud je, K se nezapne.
		if player:GetAttribute("PMenuOpen") then return end 

		setKMenuState(not isKMenuOpen)
	end
end)

-- ==========================================
-- UPDATE SLOTŮ
-- ==========================================
RunService.RenderStepped:Connect(function()
	local char = player.Character
	local tool = char and char:FindFirstChildOfClass("Tool")
	local curClass = selectedClassObj.Value
	local weaponClass = tool and tool:GetAttribute("WeaponClass") or "None"
	local isCorrect = (weaponClass == curClass)

	local curLoadout = loadoutsFolder:FindFirstChild(curClass)
	if not curLoadout then return end

	for i = 1, 5 do
		local sSlot = curLoadout.ActiveSlots:FindFirstChild("Slot"..i)
		local sName = sSlot and sSlot.Value or ""

		local gUI = gameplaySlots[i]
		gUI[2].Text = sName
		if isCorrect and sName ~= "" then
			gUI[1].BackgroundTransparency = 0.2; gUI[2].TextTransparency = 0
		else
			gUI[1].BackgroundTransparency = 0.8; gUI[2].TextTransparency = 0.6
		end

		local mUI = menuHotbarSlots[i]
		mUI[2].Text = sName
		if sName ~= "" then
			mUI[1].BackgroundTransparency = 0.2; mUI[2].TextTransparency = 0
		else
			mUI[1].BackgroundTransparency = COLORS.PanelTrans; mUI[2].TextTransparency = 0.6
		end
	end

	for i = 1, 2 do 
		local pSlot = curLoadout.PassiveSlots:FindFirstChild("Slot"..i)
		menuEqPassSlots[i].Text = pSlot and pSlot.Value or ""
	end
end)
