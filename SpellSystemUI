local function createCorner(parent, radius)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = UDim.new(0, radius or 6)
	return c
end

local function applyStroke(obj)
	local stroke = Instance.new("UIStroke", obj)
	stroke.Color = COLORS.Stroke; stroke.Thickness = 1; stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	return stroke
end

local function createText(parent, text, size, pos, align, fontSize, isTitle)
	local txt = Instance.new("TextLabel", parent)
	txt.Size = size; txt.Position = pos; txt.Text = text
	txt.TextColor3 = COLORS.Text; txt.BackgroundTransparency = 1
	txt.Font = isTitle and Enum.Font.GothamBlack or Enum.Font.GothamBold
	txt.TextSize = fontSize or 14; txt.TextXAlignment = align or Enum.TextXAlignment.Center
	return txt
end

