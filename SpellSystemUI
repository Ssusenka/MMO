-- DRAG & DROP LOGIKA
-- ==========================================
local dragScreen = Instance.new("ScreenGui", pGui); dragScreen.Name = "DragGhostGui"; dragScreen.DisplayOrder = 100; dragScreen.IgnoreGuiInset = true
local ghostIcon = Instance.new("TextLabel", dragScreen)
ghostIcon.Size = UDim2.new(0, 75, 0, 75); ghostIcon.BackgroundColor3 = COLORS.Highlight; ghostIcon.BackgroundTransparency = 0.2; ghostIcon.TextColor3 = COLORS.Text; ghostIcon.Font = Enum.Font.GothamBold; ghostIcon.TextSize = 12; ghostIcon.TextWrapped = true; ghostIcon.Visible = false; createCorner(ghostIcon, 6); applyStroke(ghostIcon)

local draggingItem = nil; local dragType = nil

local function makeDraggable(parent, name, type)
	local btn = Instance.new("TextButton", parent)
	btn.BackgroundColor3 = COLORS.SlotBg; btn.BackgroundTransparency = COLORS.PanelTrans
	createCorner(btn, 6); applyStroke(btn)
	btn.Text = name; btn.TextColor3 = COLORS.Text; btn.Font = Enum.Font.GothamBold; btn.TextSize = 12; btn.TextWrapped = true

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingItem = name; dragType = type
			ghostIcon.Text = name; ghostIcon.Visible = true
			ghostIcon.Position = UDim2.new(0, input.Position.X - 37, 0, input.Position.Y - 37)
		end
	end)
end

UIS.InputChanged:Connect(function(input)
	if draggingItem and input.UserInputType == Enum.UserInputType.MouseMovement then
		ghostIcon.Position = UDim2.new(0, input.Position.X - 37, 0, input.Position.Y - 37)
	end
end)

UIS.InputEnded:Connect(function(input)
	if draggingItem and input.UserInputType == Enum.UserInputType.MouseButton1 then
		ghostIcon.Visible = false
		local dropPos = input.Position
		local guisAtPos = pGui:GetGuiObjectsAtPosition(dropPos.X, dropPos.Y)

		for _, gui in ipairs(guisAtPos) do
			if dragType == "Spell" and gui.Name:match("^HotbarSlot(%d+)$") then
				local index = tonumber(gui.Name:match("^HotbarSlot(%d+)$"))
				remote:FireServer("EquipSpell", {index = index, name = draggingItem, class = selectedClassObj.Value})
				break
			elseif dragType == "Passive" and gui.Name:match("^EqPassSlot(%d+)$") then
				local index = tonumber(gui.Name:match("^EqPassSlot(%d+)$"))
				remote:FireServer("EquipPassive", {index = index, name = draggingItem, class = selectedClassObj.Value})
				break
			end
		end
		draggingItem = nil; dragType = nil
	end
end)

local function refreshMenu()
	for _, v in pairs(pClasses:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
	for _, v in pairs(gridSpells:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
	for _, v in pairs(gridPassives:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end

	for _, cName in pairs(CLASSES) do
		local btn = Instance.new("TextButton", pClasses)
		btn.Size = UDim2.new(0.85, 0, 0, 60); btn.BackgroundColor3 = COLORS.SlotBg; btn.BackgroundTransparency = COLORS.PanelTrans
		createCorner(btn, 6); applyStroke(btn)

		btn.Text = string.upper(cName); btn.TextColor3 = COLORS.Text; btn.Font = Enum.Font.GothamBlack; btn.TextSize = 18
		if selectedClassObj.Value == cName then 
			btn.BackgroundColor3 = COLORS.Highlight; btn.BackgroundTransparency = 0.5
		end
		btn.MouseButton1Click:Connect(function() remote:FireServer("SelectClass", cName) end)
	end

	local curClass = selectedClassObj.Value
	if SPELLS[curClass] then for _, sName in pairs(SPELLS[curClass]) do makeDraggable(gridSpells, sName, "Spell") end end
	if PASSIVES[curClass] then for _, pName in pairs(PASSIVES[curClass]) do makeDraggable(gridPassives, pName, "Passive") end end
end

selectedClassObj.Changed:Connect(function() if menuGui.Enabled then refreshMenu() end end)

-- ==========================================
-- ELEGANTNÍ ZAVÍRÁNÍ A UKLÁDÁNÍ UI
-- ==========================================
local isKMenuOpen = false
local hiddenGuis = {}

local function setKMenuState(state)
	if isKMenuOpen == state then return end
	isKMenuOpen = state

	menuGui.Enabled = isKMenuOpen
	blur.Enabled = isKMenuOpen
	hudGui.Enabled = not isKMenuOpen

	local ctrl = getControls()

	if isKMenuOpen then
		if ctrl then ctrl:Disable() end

		-- Uložíme a schováme ostatní UI
		hiddenGuis = {}
		for _, gui in ipairs(pGui:GetChildren()) do
			if gui:IsA("ScreenGui") and gui ~= menuGui and gui ~= hudGui and gui.Name ~= "DragGhostGui" and gui.Name ~= "Chat" and gui.Name ~= "BubbleChat" then
				if gui.Enabled then
					table.insert(hiddenGuis, gui)
					gui.Enabled = false
				end
			end
		end
		refreshMenu()
	else
		if ctrl then ctrl:Enable() end

		-- Vrátíme UI zpět na obrazovku
		for _, gui in ipairs(hiddenGuis) do
			if gui and gui.Parent then
				gui.Enabled = true
			end
		end
		hiddenGuis = {}
	end
end

closeBtn.MouseButton1Click:Connect(function() setKMenuState(false) end)

