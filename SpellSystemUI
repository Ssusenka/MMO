-- ==========================================
-- ELEGANTNÍ ZAVÍRÁNÍ A UKLÁDÁNÍ UI
-- ==========================================
local isKMenuOpen = false
local hiddenGuis = {}

local function setKMenuState(state)
	if isKMenuOpen == state then return end
	isKMenuOpen = state

	menuGui.Enabled = isKMenuOpen
	blur.Enabled = isKMenuOpen
	hudGui.Enabled = not isKMenuOpen

	local ctrl = getControls()

	if isKMenuOpen then
		if ctrl then ctrl:Disable() end

		-- Uložíme a schováme ostatní UI
		hiddenGuis = {}
		for _, gui in ipairs(pGui:GetChildren()) do
			if gui:IsA("ScreenGui") and gui ~= menuGui and gui ~= hudGui and gui.Name ~= "DragGhostGui" and gui.Name ~= "Chat" and gui.Name ~= "BubbleChat" then
				if gui.Enabled then
					table.insert(hiddenGuis, gui)
					gui.Enabled = false
				end
			end
		end
		refreshMenu()
	else
		if ctrl then ctrl:Enable() end

		-- Vrátíme UI zpět na obrazovku
		for _, gui in ipairs(hiddenGuis) do
			if gui and gui.Parent then
				gui.Enabled = true
			end
		end
		hiddenGuis = {}
	end
end

closeBtn.MouseButton1Click:Connect(function() setKMenuState(false) end)

