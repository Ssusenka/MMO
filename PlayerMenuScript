local function toggleMainMenu()
	menuGui.Enabled = not menuGui.Enabled

	-- HL�DA�: P menu okam�it� nahl�s� sv�j nov� stav hr��i
	game.Players.LocalPlayer:SetAttribute("PMenuOpen", menuGui.Enabled)

	local controls = PlayerModule:GetControls()
	local mainCam = workspace.CurrentCamera
	closeCtxMenu()

	if menuGui.Enabled then
		blur.Size = 20
		controls:Disable()
		mainCam.CameraType = Enum.CameraType.Scriptable 
		pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) end)
		for _, g in pairs(pGui:GetChildren()) do 
			if g:IsA("ScreenGui") and g ~= menuGui and g ~= ctxGui then 
				if g.Enabled then g:SetAttribute("WasEnabled", true) g.Enabled = false end
			end 
		end
		task.wait(0.05)
		triggerUIRefresh()
		updateStats()
	else
		blur.Size = 0
		controls:Enable()
		mainCam.CameraType = Enum.CameraType.Custom 
		pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true) end)
		pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false) end) 
		for _, g in pairs(pGui:GetChildren()) do 
			if g:IsA("ScreenGui") and g:GetAttribute("WasEnabled") then 
				g.Enabled = true g:SetAttribute("WasEnabled", nil)
			end 
		end
	end
end

