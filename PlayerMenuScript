local function handleMenuInputs(actionName, inputState, inputObject)
	if inputState == Enum.UserInputState.Begin then
		if actionName == "ToggleMainMenu" then
			-- OCHRANN� BLBOST: Pokud se sna�� zapnout P menu, ale K menu je otev�en�...
			if not menuGui.Enabled and game.Players.LocalPlayer:GetAttribute("KMenuOpen") then
				-- Skript propust� sign�l (Pass). D�ky tomu si K menu v�imne, �e jsi zm��kl P, 
				-- a samo se zav�e. Ty pak jen zm��kne� P znovu a v klidu se otev�e.
				return Enum.ContextActionResult.Pass
			end

			toggleMainMenu()
		elseif actionName == "ToggleQuickInv" then
			toggleQuickInv()
		end
	end
	return Enum.ContextActionResult.Sink
end

