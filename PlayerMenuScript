local charClone = nil
local currentRot = 0 
local vpfCamera = Instance.new("Camera")

local function setupDynamicViewport()
	vpf:ClearAllChildren()
	local char = player.Character or player.CharacterAdded:Wait()
	char.Archivable = true
	local worldModel = Instance.new("WorldModel")
	worldModel.Parent = vpf

	charClone = char:Clone()

	local idleAnimId = "rbxassetid://507766388" 
	if char:FindFirstChild("Humanoid") and char.Humanoid.RigType == Enum.HumanoidRigType.R6 then
		idleAnimId = "rbxassetid://180435571" 
	end

	local animateScript = char:FindFirstChild("Animate")
	if animateScript and animateScript:FindFirstChild("idle") then
		local animObj = animateScript.idle:FindFirstChildOfClass("Animation")
		if animObj then idleAnimId = animObj.AnimationId end
	end

	for _, v in pairs(charClone:GetDescendants()) do
		if v:IsA("Script") or v:IsA("LocalScript") then v:Destroy() end
	end

	charClone.Parent = worldModel
	charClone:PivotTo(CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(currentRot), 0))

	local humanoid = charClone:FindFirstChild("Humanoid")
	if humanoid then
		local animator = humanoid:FindFirstChild("Animator") or Instance.new("Animator", humanoid)
		local animation = Instance.new("Animation")
		animation.AnimationId = idleAnimId
		local track = animator:LoadAnimation(animation)
		track.Looped = true
		track:Play()
	end

	local charCFrame, charSize = charClone:GetBoundingBox()
	local targetPos = charCFrame.Position
	vpfCamera.FieldOfView = 22 

	local distance = (charSize.Y / 2) / math.tan(math.rad(vpfCamera.FieldOfView / 2))
	vpfCamera.CFrame = CFrame.lookAt(targetPos + Vector3.new(0, 0, -distance * 1.1), targetPos)

	vpf.CurrentCamera = vpfCamera
	vpfCamera.Parent = vpf
end

