local function setupAutoRefresh()
	local char = player.Character or player.CharacterAdded:Wait()
	char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then triggerUIRefresh() end
	end)
	char.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") then triggerUIRefresh() end
	end)

	local backpack = player:WaitForChild("Backpack")
	backpack.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then triggerUIRefresh() end
	end)
	backpack.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") then triggerUIRefresh() end
	end)
end

local function autoEquipSavedGear()
	local gearFolder = player:WaitForChild("EquippedGear", 10)
	if not gearFolder then return end

	local savedWeapon = gearFolder:WaitForChild("Weapon").Value
	if savedWeapon ~= "" then
		task.spawn(function()
			local backpack = player:WaitForChild("Backpack")
			local tool = backpack:FindFirstChild(savedWeapon)
			local attempts = 0

			while not tool and attempts < 10 do
				task.wait(0.5)
				tool = backpack:FindFirstChild(savedWeapon)
				attempts = attempts + 1
			end

			local char = player.Character or player.CharacterAdded:Wait()
			local humanoid = char:WaitForChild("Humanoid")
			local currentlyEquipped = char:FindFirstChildOfClass("Tool")

			if tool and humanoid and not currentlyEquipped then
				humanoid:EquipTool(tool)
				triggerUIRefresh()
			end
		end)
	end
end

local function onCharacterSpawned()
	setupAutoRefresh()
	autoEquipSavedGear()
end

player.CharacterAdded:Connect(onCharacterSpawned)
if player.Character then onCharacterSpawned() end
