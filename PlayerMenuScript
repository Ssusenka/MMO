local function releaseDrag(mx, my)
	if not dragGhost then return end

	local wSlot = equipSlots["Weapon"].Btn
	local wPos = wSlot.AbsolutePosition
	local wSize = wSlot.AbsoluteSize

	local droppedOnWeapon = (mx >= wPos.X and mx <= wPos.X + wSize.X and my >= wPos.Y and my <= wPos.Y + wSize.Y)
	local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")

	local stateChanged = false

	if draggingFromEquip then
		if not droppedOnWeapon and humanoid then
			humanoid:UnequipTools()
			updateGearEvent:FireServer("Weapon", "") 
			stateChanged = true
		end
	else
		if droppedOnWeapon and humanoid and draggingItemObj then
			humanoid:EquipTool(draggingItemObj)
			updateGearEvent:FireServer("Weapon", draggingItemObj.Name) 
			stateChanged = true
		end
	end

	dragGhost:Destroy()
	dragGhost = nil
	draggingItemObj = nil
	draggingFromEquip = false

	if stateChanged then triggerUIRefresh() end
end

